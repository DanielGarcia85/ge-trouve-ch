# Modèle de configuration — copier en `.env` (jamais commité) et compléter.
# Aucune valeur sensible ne doit figurer ici, uniquement des exemples.

# --- LLM local (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b

# --- Base vectorielle ---
CHROMA_PERSIST_DIR=./data/chroma

# --- Chemins de données ---
DATA_DIR=./data
