# --- Secrets (le .env n'est jamais commité ; .env.example sert de modèle) ---
.env
.env.*
!.env.example

# --- Configuration éditeur VS Code ---
# On versionne uniquement settings.json (réglages partagés, interpréteur via
# ${env:LOCAL_PC_VENV}) ; tout le reste de .vscode/ reste local à la machine.
.vscode/*
!.vscode/settings.json

# --- Données scrapées (dossier présent, contenu non versionné — voir CLAUDE.md) ---
data/*
!data/.gitkeep

# --- Fichiers temporaires Office (le mémoire est ouvert en édition) ---
~$*.docx

# --- Environnement Claude Code (historique, config — jamais versionné) ---
.claude/

# --- Contexte projet pour l'assistant ---
CLAUDE.md
